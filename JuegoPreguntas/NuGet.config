<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
	<!-- Fuente pública de NuGet: usada para resolver los targeting packs y paquetes necesarios -->
	<add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
  <!-- ActivePackageSource opcional: Visual Studio/CLI usará las fuentes listadas arriba -->
  <activePackageSource>
	<add key="All" value="(Aggregate source)" />
  </activePackageSource>
</configuration>
